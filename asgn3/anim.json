{
  "_comment": "Frantic Backrooms-entity walk cycle. 1.0 s loop. Translations in OBJ units (~20 = full-body height). Rotations in DEGREES (Euler XYZ, applied around the named pivot). The OBJ rest pose faces +X, so 'forward swing' = rotation about Z (lateral axis), and 'side-to-side roll' = rotation about X (forward axis).",
  "duration": 1.0,
  "nodes": {

    "body": {
      "_comment": "Root rocking + vertical bob. Pivot near hips. X-roll = side-to-side weight shift (around forward axis), Z-tilt = subtle forward lurch (around lateral axis).",
      "pivot": [0.0, 8.0, 0.0],
      "keyframes": [
        { "time": 0.00, "translation": [0,  0.00, 0], "rotation": [-4,  0,  2] },
        { "time": 0.25, "translation": [0,  0.30, 0], "rotation": [ 4,  3, -1] },
        { "time": 0.50, "translation": [0, -0.05, 0], "rotation": [-4,  0,  2] },
        { "time": 0.75, "translation": [0,  0.30, 0], "rotation": [ 4, -3, -1] },
        { "time": 1.00, "translation": [0,  0.00, 0], "rotation": [-4,  0,  2] }
      ]
    },

    "head": {
      "_comment": "Erratic twitching. Y = look left/right (yaw), Z = nod up/down (around lateral axis).",
      "pivot": [0.0, 16.5, 0.0],
      "keyframes": [
