        { "time": 1.00, "translation": [0, 0, 0], "rotation": [-22,   8,  65] }
      ]
    },

    "arm_right": {
      "_comment": "Opposite-phase flail with different amplitudes so the arms never look mirror-symmetric.",
      "pivot": [0.2, 16.4, 0.6],
      "keyframes": [
        { "time": 0.00, "translation": [0, 0, 0], "rotation": [ 20,  -7, -60] },
        { "time": 0.25, "translation": [0, 0, 0], "rotation": [-25,  10,  70] },
        { "time": 0.50, "translation": [0, 0, 0], "rotation": [ 26, -12, -72] },
