        { "time": 0.13, "translation": [0, 0, 0], "rotation": [ -8,  22, -10] },
        { "time": 0.27, "translation": [0, 0, 0], "rotation": [ 12,  -6,   4] },
        { "time": 0.41, "translation": [0, 0, 0], "rotation": [  3, -28,  12] },
        { "time": 0.58, "translation": [0, 0, 0], "rotation": [ -9,  16,  -7] },
        { "time": 0.72, "translation": [0, 0, 0], "rotation": [  6, -14,   9] },
        { "time": 0.85, "translation": [0, 0, 0], "rotation": [ -3,  10,  -4] },
        { "time": 1.00, "translation": [0, 0, 0], "rotation": [  4, -18,   6] }
      ]
    },

    "arm_left": {
      "_comment": "Wild flail. Z-rotation = forward/back swing at shoulder (around lateral axis); X-rotation = side splay (around forward axis).",
      "pivot": [-0.7, 16.4, -2.3],
      "keyframes": [
        { "time": 0.00, "translation": [0, 0, 0], "rotation": [-22,   8,  65] },
        { "time": 0.25, "translation": [0, 0, 0], "rotation": [ 28,  -6, -55] },
